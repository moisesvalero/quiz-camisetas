---
import Layout from '../layouts/Layout.astro';
import QuizGame from '../components/QuizGame.astro';
import { buildShirtImageMap } from '../data/shirts-images';

const imageMap = await buildShirtImageMap();
---

<Layout title="Shirt Quiz — Camisetas de Selecciones Nacionales">
	<main class="app-container">
		<QuizGame />
	</main>
	<script id="shirt-image-map" type="application/json" set:html={JSON.stringify(imageMap)} is:inline></script>
</Layout>
