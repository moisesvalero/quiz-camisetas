---
import '../styles/index.css';

interface Props {
	title?: string;
}

const { title = 'Retro Shirt Quiz — Mundiales de Fútbol' } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
		<meta name="theme-color" content="#06120c" />

		<title>{title}</title>
		<meta name="description" content="El quiz definitivo de camisetas históricas del Mundial. 50 leyendas, 3 modos de juego, récords y pistas. ¿Cuántas reconoces?" />
		<meta name="robots" content="index, follow" />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="Adivina la selección o el año de 50 camisetas legendarias de los Mundiales." />
		<meta property="og:image" content="/icon-512.png" />

		<link rel="manifest" href="/manifest.json" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/icon-512.png" />

		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="Retro Shirt Quiz" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	</head>
	<body>
		<div class="scene" aria-hidden="true">
			<div class="scene__orb scene__orb--green"></div>
			<div class="scene__orb scene__orb--gold"></div>
			<div class="scene__lines"></div>
		</div>

		<slot />

		<script is:inline>
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register('/sw.js').catch(() => {});
				});
			}
		</script>
	</body>
</html>
