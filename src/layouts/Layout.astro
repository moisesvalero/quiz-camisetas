---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'Shirt Quiz — Camisetas de Selecciones' } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
		<meta name="theme-color" content="#f9f9f9" />

		<title>{title}</title>
		<meta name="description" content="Adivina la selección y el año de cada camiseta. Más de 175 equipaciones de selecciones nacionales de todo el mundo y todas las épocas." />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href="https://quiz-camisetas.moisesvalero.es" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://quiz-camisetas.moisesvalero.es" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="Adivina la selección y el año de cada camiseta. Más de 175 equipaciones de todas las épocas." />
		<meta property="og:image" content="https://quiz-camisetas.moisesvalero.es/images/og-image.png" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://quiz-camisetas.moisesvalero.es" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content="Adivina la selección y el año de cada camiseta. Más de 175 equipaciones de todas las épocas." />
		<meta property="twitter:image" content="https://quiz-camisetas.moisesvalero.es/images/og-image.png" />

		<link rel="manifest" href="/manifest.json" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/icon-512.png" />
		<link rel="apple-touch-icon-precomposed" href="/icon-512.png" />

		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="Shirt Quiz" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;900&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet" />
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
	</head>
	<body class="unity-pulse-bg stadium-mesh flex flex-col font-body-md">
		<slot />

		<script is:inline>
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register('/sw.js').catch(() => {});
				});
			}
		</script>
	</body>
</html>
