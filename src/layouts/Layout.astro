---
import { Font } from 'astro:assets'
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Shirt Quiz — Camisetas de Selecciones',
  description = 'Adivina la selección y el año de cada camiseta. Más de 175 equipaciones de selecciones nacionales de todo el mundo y todas las épocas.',
} = Astro.props

const SITE_URL = 'https://quiz-camisetas.moisesvalero.es'
const OG_IMAGE = `${SITE_URL}/images/og-image.png`
const CURRENT_URL = SITE_URL

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE_URL}#website`,
  url: SITE_URL,
  name: 'Retro Shirt Quiz',
  alternateName: 'Shirt Quiz — Camisetas de Selecciones',
  description,
  inLanguage: 'es',
  publisher: { '@id': `${SITE_URL}#org` },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${SITE_URL}/?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
}

const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE_URL}#org`,
  name: 'Retro Shirt Quiz',
  url: SITE_URL,
  logo: {
    '@type': 'ImageObject',
    url: `${SITE_URL}/icon-512.png`,
    width: 512,
    height: 512,
  },
  image: { '@type': 'ImageObject', url: OG_IMAGE },
  sameAs: ['https://github.com/moisesvalero/quiz-camisetas'],
}

const webAppLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': `${SITE_URL}#app`,
  name: 'Retro Shirt Quiz',
  url: CURRENT_URL,
  description,
  inLanguage: 'es',
  applicationCategory: 'GameApplication',
  applicationSubCategory: 'Quiz',
  operatingSystem: 'Any (Web)',
  browserRequirements:
    'Requires JavaScript, requires modern browser with Canvas, AudioContext, Service Worker and IndexedDB support',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'EUR',
    availability: 'https://schema.org/InStock',
  },
  author: { '@id': `${SITE_URL}#org` },
  publisher: { '@id': `${SITE_URL}#org` },
  image: { '@type': 'ImageObject', url: OG_IMAGE },
  screenshot: {
    '@type': 'ImageObject',
    url: `${SITE_URL}/images/hero_banner.png`,
  },
  featureList:
    'Three difficulty modes, score and streak tracking, PWA install, offline play, responsive design',
  keywords:
    'quiz,camisetas,futbol,mundial,selecciones,national team kits,world cup,football,shirts,trivia,game,offline,PWA',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    ratingCount: '120',
    bestRating: '5',
    worstRating: '1',
  },
}

const gameLd = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  '@id': `${SITE_URL}#game`,
  name: 'Retro Shirt Quiz — National Team Kits Edition',
  url: CURRENT_URL,
  description,
  inLanguage: 'es',
  image: OG_IMAGE,
  author: { '@id': `${SITE_URL}#org` },
  publisher: { '@id': `${SITE_URL}#org` },
  genre: ['Quiz', 'Trivia', 'Educational'],
  gamePlatform: ['Web Browser', 'PWA', 'Android', 'iOS'],
  playMode: 'SinglePlayer',
  applicationCategory: 'GameApplication',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
}

const breadcrumbsLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Inicio',
      item: SITE_URL,
    },
  ],
}

const speakableLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${CURRENT_URL}#page`,
  url: CURRENT_URL,
  name: title,
  description,
  inLanguage: 'es',
  isPartOf: { '@id': `${SITE_URL}#website` },
  about: { '@id': `${SITE_URL}#game` },
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: [
      'h1',
      '.js-question-text',
      '.js-feedback-title',
      '.js-game-over-message',
    ],
  },
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover"
    />
    <meta
      name="theme-color"
      content="#f9f9f9"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#1b1b1b"
      media="(prefers-color-scheme: dark)"
    />
    <meta name="color-scheme" content="light" />
    <meta name="format-detection" content="telephone=no" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta name="googlebot" content="index, follow" />
    <meta name="author" content="moisesvalero" />
    <meta name="publisher" content="Retro Shirt Quiz" />
    <meta name="application-name" content="Shirt Quiz" />
    <meta name="generator" content="Astro" />
    <meta name="rating" content="general" />
    <meta name="distribution" content="global" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="language" content="Spanish" />
    <meta name="geo.region" content="ES" />
    <meta name="geo.placename" content="Spain" />
    <meta name="ICBM" content="40.4168, -3.7038" />
    <meta name="category" content="Games, Trivia, Sports" />
    <meta name="copyright" content="© 2026 Retro Shirt Quiz" />

    <meta
      name="keywords"
      content="quiz,camisetas,futbol,fútbol,selecciones,mundial,world cup,trivia,national team kits,football kits,retro shirts,equipaciones,adivina camiseta,juego de camisetas,quiz de futbol,juego trivia,PWA,offline,brutalist"
    />

    <link rel="canonical" href={SITE_URL} />
    <link rel="alternate" href={SITE_URL} hreflang="es" />
    <link rel="alternate" href={SITE_URL} hreflang="x-default" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Retro Shirt Quiz" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:url" content={CURRENT_URL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:image:secure_url" content={OG_IMAGE} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Retro Shirt Quiz — Camisetas históricas del Mundial"
    />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@moisesvalero" />
    <meta name="twitter:creator" content="@moisesvalero" />
    <meta name="twitter:url" content={CURRENT_URL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />
    <meta
      name="twitter:image:alt"
      content="Retro Shirt Quiz — Camisetas históricas del Mundial"
    />

    <!-- Fonts via Astro 7 native Font API -->
    <Font cssVariable="--font-outfit" preload />
    <Font cssVariable="--font-jetbrains-mono" preload />
    <Font cssVariable="--font-material-symbols" preload />

    <!-- Performance hints -->
    <link
      rel="preload"
      href="/images/og-image.png"
      as="image"
      fetchpriority="high"
    />

    <link rel="manifest" href="/manifest.json" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/icon-512.png" />
    <link rel="apple-touch-icon-precomposed" href="/icon-512.png" />

    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="black-translucent"
    />
    <meta name="apple-mobile-web-app-title" content="Shirt Quiz" />

    <!-- Structured data: WebSite + SearchAction -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(websiteLd)}
    />
    <!-- Structured data: Organization -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(organizationLd)}
    />
    <!-- Structured data: WebApplication (PWA) -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(webAppLd)}
    />
    <!-- Structured data: VideoGame -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(gameLd)}
    />
    <!-- Structured data: BreadcrumbList -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(breadcrumbsLd)}
    />
    <!-- Structured data: Speakable (AEO) -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(speakableLd)}
    />
  </head>
  <body class="unity-pulse-bg stadium-mesh flex flex-col font-body-md">
    <slot />

    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {})
        })
      }
    </script>
  </body>
</html>
