---
import '../styles/index.css';

interface Props {
	title?: string;
}

const { title = "Retro Shirt Quiz - World Cup" } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
		<meta name="theme-color" content="#060908" />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content="Quiz interactivo de camisetas históricas de los Mundiales de Fútbol con fotos reales. ¡Adivina el equipo o el año!" />
		<meta name="robots" content="index, follow" />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="Quiz interactivo de camisetas históricas de los Mundiales de Fútbol con fotos reales. ¡Adivina el equipo o el año!" />
		<meta property="og:image" content="/icon-512.png" />

		<!-- PWA Web Manifest & Icons -->
		<link rel="manifest" href="/manifest.json" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/icon-512.png" />
		
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="Quiz Camisetas" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	</head>
	<body>
		<slot />

		<!-- PWA Service Worker Registration -->
		<script is:inline>
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register('/sw.js')
						.then((reg) => console.log('Service Worker registrado con éxito:', reg.scope))
						.catch((err) => console.error('Fallo al registrar el Service Worker:', err));
				});
			}
		</script>
	</body>
</html>
