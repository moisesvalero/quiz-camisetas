---
---

<div class="quiz-game-wrapper w-full min-h-screen">
  <canvas id="confetti-canvas" class="confetti-canvas" aria-hidden="true"></canvas>

  <!-- ==================== PANTALLAS DE INICIO ==================== -->
  <div id="start-screen" class="js-start-screen w-full">
    <!-- MÓVIL (md:hidden) -->
    <div class="md:hidden flex flex-col w-full max-w-md mx-auto px-4 pt-12 pb-8">
      <header class="text-center mb-10 stagger-load">
        <div class="inline-block bg-primary text-on-primary font-label-mono text-[11px] px-3 py-1 mb-4 border-[2px] border-black">
          JERSEY PRO EDITION
        </div>
        <h1 class="font-display-xl-mobile text-display-xl-mobile leading-[1.1] tracking-tighter uppercase font-black text-primary italic">
          RETRO<br/>SHIRT<br/><span class="text-outline border-b-4 border-primary">QUIZ</span>
        </h1>
      </header>
      
      <section class="grid grid-cols-2 gap-4 mb-8 stagger-load delay-1">
        <div class="bento-card bento-card-shadow p-4 flex flex-col items-center justify-center">
          <span class="font-label-mono text-[9px] text-secondary uppercase mb-1">Racha Maxima</span>
          <div class="flex items-center gap-1">
            <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">local_fire_department</span>
            <span class="font-headline-md text-headline-md js-global-max-streak">0</span>
          </div>
        </div>
        <div class="bento-card bento-card-shadow p-4 flex flex-col items-center justify-center">
          <span class="font-label-mono text-[9px] text-secondary uppercase mb-1">Mejor Record</span>
          <div class="flex items-center gap-1">
            <span class="material-symbols-outlined text-primary">emoji_events</span>
            <span class="font-headline-md text-headline-md js-global-high-score">0</span>
          </div>
        </div>
      </section>

      <section class="flex flex-col gap-4 flex-grow stagger-load delay-2">
        <button class="bento-card bento-card-shadow text-left p-5 group relative overflow-hidden js-mode-button" data-mode="team">
          <div class="flex justify-between items-start mb-2">
            <div class="bg-primary text-on-primary p-2 border-[2px] border-black">
              <span class="material-symbols-outlined text-[24px]">flag</span>
            </div>
            <span class="font-label-mono text-[12px] opacity-40">MODE 01</span>
          </div>
          <h3 class="font-headline-md text-headline-md mb-1 uppercase">Adivinar Seleccion</h3>
          <p class="font-body-md text-on-surface-variant leading-tight">Identifica el pais por sus equipaciones historicas mas iconicas.</p>
          <div class="mt-4 flex items-center text-primary font-label-mono text-xs group-hover:translate-x-1 transition-transform">
            PLAY NOW <span class="material-symbols-outlined ml-1">arrow_forward</span>
          </div>
        </button>
        <button class="bento-card bento-card-shadow text-left p-5 group relative overflow-hidden js-mode-button" data-mode="year">
          <div class="flex justify-between items-start mb-2">
            <div class="bg-white text-primary p-2 border-[2px] border-black">
              <span class="material-symbols-outlined text-[24px]">calendar_today</span>
            </div>
            <span class="font-label-mono text-[12px] opacity-40">MODE 02</span>
          </div>
          <h3 class="font-headline-md text-headline-md mb-1 uppercase">Adivinar Año</h3>
          <p class="font-body-md text-on-surface-variant leading-tight">¿En que mundial se uso esta camiseta? Pon a prueba tu memoria temporal.</p>
          <div class="mt-4 flex items-center text-primary font-label-mono text-xs group-hover:translate-x-1 transition-transform">
            PLAY NOW <span class="material-symbols-outlined ml-1">arrow_forward</span>
          </div>
        </button>
        <button class="bento-card bento-card-shadow text-left p-5 group relative overflow-hidden bg-primary-container text-on-primary js-mode-button" data-mode="mixed">
          <div class="flex justify-between items-start mb-2">
            <div class="bg-white text-primary p-2 border-[2px] border-black">
              <span class="material-symbols-outlined text-[24px]">shuffle</span>
            </div>
            <span class="font-label-mono text-[12px] opacity-40">MODE 03</span>
          </div>
          <h3 class="font-headline-md text-headline-md mb-1 uppercase text-white">Modo Mixto</h3>
          <p class="font-body-md text-on-primary-container leading-tight">El desafio definitivo. Seleccion y año mezclados de forma aleatoria.</p>
          <div class="mt-4 flex items-center text-white font-label-mono text-xs group-hover:translate-x-1 transition-transform">
            PLAY NOW <span class="material-symbols-outlined ml-1">bolt</span>
          </div>
        </button>
      </section>

      <footer class="mt-10 flex flex-col items-center gap-6 stagger-load delay-3">
        <div class="flex flex-col items-center gap-3">
          <div class="text-[11px] text-on-surface-variant opacity-60">
            Desarrollado por <a href="https://github.com/moisesvalero" target="_blank" rel="noopener noreferrer" class="font-bold underline">Moisés Valero</a>
          </div>
          <a href="https://www.paypal.com/cgi-bin/webscr?cmd=_donations&business=moi6%40outlook%2ecom&lc=ES&item_name=Retro%20Shirt%20Quiz&currency_code=EUR" target="_blank" rel="noopener noreferrer" class="btn-donate">
            Apoya el proyecto ❤️
          </a>
        </div>
        <p class="font-label-mono text-[9px] text-on-surface-variant opacity-40 uppercase tracking-widest text-center">
          © 2026 JERSEY PRO • FIFA 2026 UNITY PULSE
        </p>
      </footer>
    </div>

    <!-- TABLET / ESCRITORIO (hidden md:block) -->
    <div class="hidden md:block w-full max-w-5xl mx-auto px-12 pt-12 pb-24">
      <section class="text-center mb-12 stagger-load">
        <h1 class="font-display-xl text-7xl uppercase leading-none tracking-tighter italic mb-2">RETRO SHIRT QUIZ</h1>
        <p class="font-label-mono text-label-mono text-secondary uppercase tracking-widest">Identifica las camisetas mas legendarias de los mundiales • 1930 - 2022</p>
      </section>
      
      <div class="grid grid-cols-12 gap-4 stagger-load delay-1">
        <div class="col-span-12 h-64 border-2 border-primary overflow-hidden relative bento-card brutalist-shadow">
          <div class="absolute inset-0 bg-black/10 z-10"></div>
          <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 hover:scale-105" style="background-image: url('/images/hero_banner.png')"></div>
          <div class="absolute bottom-6 left-6 z-20 bg-primary text-on-primary border-[2px] border-black px-4 py-2 brutalist-shadow">
            <span class="font-headline-md text-xl uppercase tracking-widest italic text-white">RETRO WORLD CUP KITS</span>
          </div>
        </div>
        
        <button class="col-span-4 h-64 bg-surface-container-lowest border-2 border-primary p-6 flex flex-col justify-between text-left bento-card brutalist-shadow group cursor-pointer js-mode-button" data-mode="team">
          <div class="flex justify-between w-full">
            <span class="material-symbols-outlined text-primary text-3xl">flag</span>
            <span class="font-label-mono text-[10px] bg-primary text-on-primary px-2 py-1 uppercase">MODO 01</span>
          </div>
          <div>
            <h3 class="font-headline-md text-xl text-primary uppercase font-bold">Adivinar Selección</h3>
            <p class="font-label-mono text-xs text-secondary mt-2">Identifica países por los diseños de sus camisetas oficiales.</p>
          </div>
        </button>
        
        <button class="col-span-4 h-64 bg-surface-container-lowest border-2 border-primary p-6 flex flex-col justify-between text-left bento-card brutalist-shadow group cursor-pointer js-mode-button" data-mode="year">
          <div class="flex justify-between w-full">
            <span class="material-symbols-outlined text-primary text-3xl">calendar_today</span>
            <span class="font-label-mono text-[10px] bg-primary text-on-primary px-2 py-1 uppercase">MODO 02</span>
          </div>
          <div>
            <h3 class="font-headline-md text-xl text-primary uppercase font-bold">Adivinar Año</h3>
            <p class="font-label-mono text-xs text-secondary mt-2">¿En qué Copa del Mundo se usó este uniforme histórico?</p>
          </div>
        </button>

        <button class="col-span-4 h-64 bg-primary border-2 border-primary p-6 flex flex-col justify-between text-left bento-card brutalist-shadow group cursor-pointer js-mode-button" data-mode="mixed">
          <div class="flex justify-between w-full">
            <span class="material-symbols-outlined text-on-primary text-3xl text-white">shuffle</span>
            <span class="font-label-mono text-[10px] bg-white text-primary px-2 py-1 uppercase font-bold">MODO 03</span>
          </div>
          <div>
            <h3 class="font-headline-md text-xl text-on-primary uppercase font-bold text-white">Modo Mixto</h3>
            <p class="font-label-mono text-xs text-on-primary opacity-80 mt-2">El desafío definitivo. Mezcla aleatoria de países y años.</p>
          </div>
        </button>
        
        <div class="col-span-12 border-2 border-primary p-6 flex items-center justify-between bg-surface-container-lowest bento-card">
          <div class="flex items-center gap-8">
            <div class="flex flex-col">
              <span class="font-label-mono text-[10px] text-secondary uppercase">Desarrollador</span>
              <a href="https://github.com/moisesvalero" target="_blank" rel="noopener noreferrer" class="font-headline-md text-lg underline">Moisés Valero</a>
            </div>
            <div class="h-8 w-[1px] bg-outline-variant"></div>
            <div class="flex flex-col">
              <span class="font-label-mono text-[10px] text-secondary uppercase">Proveedor de datos</span>
              <a href="https://www.footballkitarchive.com/world-cup-kits-l308/" target="_blank" rel="noopener noreferrer" class="font-headline-md text-lg underline">Football Kit Archive</a>
            </div>
          </div>
          <a href="https://www.paypal.com/cgi-bin/webscr?cmd=_donations&business=moi6%40outlook%2ecom&lc=ES&item_name=Retro%20Shirt%20Quiz&currency_code=EUR" target="_blank" rel="noopener noreferrer" class="btn-donate">
            Apoya el proyecto ❤️
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ==================== PANTALLAS DE JUEGO ==================== -->
  <div id="game-screen" class="js-game-screen hidden w-full">
    <!-- MÓVIL (md:hidden) -->
    <div class="md:hidden flex flex-col w-full max-w-md mx-auto min-h-screen">
      <header class="w-full px-4 pt-6 pb-2 flex flex-col gap-4 sticky top-0 bg-background z-20">
        <div class="flex justify-between items-center">
          <div class="flex flex-col">
            <span class="font-label-mono text-label-mono text-secondary uppercase tracking-widest text-[9px]">RACHA</span>
            <span class="font-headline-md text-headline-md text-primary js-current-streak">0</span>
          </div>
          <div class="flex flex-col items-center gap-1">
            <span class="font-label-mono text-[9px] text-secondary uppercase tracking-wider">VIDAS</span>
            <div class="flex gap-1">
              <span class="material-symbols-outlined text-[#FF007A] text-[20px] js-heart" style="font-variation-settings: 'FILL' 1;">favorite</span>
              <span class="material-symbols-outlined text-[#FF007A] text-[20px] js-heart" style="font-variation-settings: 'FILL' 1;">favorite</span>
              <span class="material-symbols-outlined text-[#FF007A] text-[20px] js-heart" style="font-variation-settings: 'FILL' 1;">favorite</span>
            </div>
          </div>
          <div class="flex flex-col items-end">
            <span class="font-label-mono text-label-mono text-secondary uppercase tracking-widest text-[9px]">PUNTOS</span>
            <span class="font-headline-md text-headline-md text-primary js-current-score">0</span>
          </div>
        </div>
        <div class="w-full h-3 bg-surface-container border-2 border-primary relative overflow-hidden">
          <div class="h-full bg-neon-pink border-r-2 border-primary transition-all duration-300 js-progress-fill" style="width: 0%;"></div>
        </div>
      </header>
      
      <main class="flex-grow overflow-y-auto px-4 py-4 flex flex-col gap-5">
        <section class="w-full aspect-[4/5] bg-white border-2 border-primary brutalist-button-shadow flex items-center justify-center p-6 relative overflow-hidden">
          <div class="absolute -top-10 -right-10 w-40 h-40 bg-electric-turquoise opacity-20 rotate-12"></div>
          <div class="w-full h-full relative z-10 flex items-center justify-center">
            <div class="absolute inset-0 bg-white flex items-center justify-center js-image-loader">
              <div class="w-10 h-10 border-4 border-black border-t-transparent animate-spin"></div>
            </div>
            <img class="w-full h-full object-contain hidden js-shirt-image" src="" alt="Camiseta retro del mundial" />
          </div>
          <div class="absolute bottom-4 left-4 bg-primary text-on-primary px-3 py-1 font-label-mono text-[9px] tracking-widest js-question-type-badge">
            SELECCION
          </div>
        </section>
        
        <div class="flex flex-col items-center">
          <button class="js-btn-hint btn-hint" type="button">💡 Ver pista de color</button>
          <div class="js-hint-box hint-text hidden"></div>
        </div>

        <div class="flex flex-col gap-1">
          <span class="font-label-mono text-label-mono text-secondary flex items-center gap-1.5">
            <span class="material-symbols-outlined text-[15px]">quiz</span> PREGUNTA <span class="js-question-index">1</span>
          </span>
          <h2 class="font-headline-lg-mobile text-headline-lg-mobile text-primary uppercase leading-tight js-question-text">
            ¿A que seleccion pertenece esta camiseta?
          </h2>
        </div>
        
        <div class="flex flex-col gap-3 pb-8 js-options-grid">
           <!-- Opciones móviles -->
        </div>
      </main>
      
      <footer class="bg-primary text-on-primary py-4 px-6 flex justify-between items-center sticky bottom-0 z-20">
        <button class="flex items-center gap-2 group js-btn-home">
          <span class="material-symbols-outlined text-white">arrow_back</span>
          <span class="font-label-mono text-label-mono text-white uppercase tracking-widest">Abandonar</span>
        </button>
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-electric-turquoise" style="font-variation-settings: 'FILL' 1;">bolt</span>
          <span class="font-label-mono text-label-mono text-electric-turquoise js-streak-badge hidden">RACHA ACTIVA</span>
        </div>
      </footer>
    </div>

    <!-- TABLET / ESCRITORIO (hidden md:flex) -->
    <div class="hidden md:flex flex-col w-full min-h-screen">
      <header class="w-full h-20 flex items-center justify-between px-12 z-10 border-b-2 border-primary bg-white">
        <div class="flex items-center gap-4">
          <div class="bento-border bg-primary text-on-primary px-4 py-2 flex items-center gap-2">
            <span class="material-symbols-outlined text-on-primary">local_fire_department</span>
            <span class="font-label-mono text-label-mono">RACHA: <span class="js-current-streak">0</span></span>
          </div>
          <div class="bento-border bg-surface-container-lowest px-4 py-2">
            <span class="font-label-mono text-label-mono text-primary uppercase font-bold">PREGUNTA <span class="js-question-index">1</span></span>
          </div>
          <div class="flex items-center gap-1.5 ml-2">
            <span class="material-symbols-outlined text-[#FF007A] text-[26px] js-heart" style="font-variation-settings: 'FILL' 1;">favorite</span>
            <span class="material-symbols-outlined text-[#FF007A] text-[26px] js-heart" style="font-variation-settings: 'FILL' 1;">favorite</span>
            <span class="material-symbols-outlined text-[#FF007A] text-[26px] js-heart" style="font-variation-settings: 'FILL' 1;">favorite</span>
          </div>
        </div>
        <div class="hidden md:block font-display-xl text-primary font-black tracking-tighter text-[28px] italic">
          RETRO SHIRT QUIZ
        </div>
        <div class="flex items-center gap-6">
          <div class="flex flex-col items-end">
            <span class="font-label-mono text-xs uppercase opacity-60 tracking-widest">Puntos Actuales</span>
            <span class="font-display-xl text-[40px] leading-none text-primary js-current-score">0</span>
          </div>
          <button class="bento-border bg-surface-container-lowest p-2 hover:bg-red-50 hover:text-red-600 transition-colors js-btn-home">
            <span class="material-symbols-outlined">close</span>
          </button>
        </div>
      </header>

      <main class="flex-grow flex flex-col items-center justify-center px-12 pb-12 gap-6 relative z-10">
        <div class="w-full max-w-4xl h-3 bento-border bg-surface-container-highest relative mt-6 mb-2">
          <div class="absolute inset-y-0 left-0 bg-primary transition-all duration-300 js-progress-fill" style="width: 0%;"></div>
          <div class="absolute -top-6 left-[0%] transform -translate-x-1/2 transition-all duration-300" id="soccer-indicator-tablet">
            <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">sports_soccer</span>
          </div>
        </div>
        
        <div class="flex flex-row items-center justify-center gap-12 w-full max-w-5xl">
          <div class="w-1/2 flex justify-center">
            <div class="bento-border bg-surface-container-lowest p-8 relative w-full aspect-square max-w-[400px] flex items-center justify-center group">
              <div class="absolute top-4 left-4">
                <span class="font-label-mono text-label-mono bg-primary text-on-primary px-3 py-1 js-question-type-badge">SELECCION</span>
              </div>
              <div class="w-full h-full flex items-center justify-center relative">
                <div class="absolute inset-0 bg-white flex items-center justify-center js-image-loader">
                  <div class="w-12 h-12 border-4 border-black border-t-transparent animate-spin"></div>
                </div>
                <img class="max-w-full max-h-full object-contain hidden js-shirt-image" src="" alt="Camiseta historica del mundial" />
              </div>
              <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-primary-container -z-10"></div>
            </div>
          </div>
          
          <div class="w-1/2 flex flex-col gap-4">
            <div class="mb-2">
              <h2 class="font-headline-lg text-3xl text-primary uppercase tracking-tighter leading-none js-question-text">
                ¿A que seleccion pertenece esta camiseta?
              </h2>
            </div>
            <div class="mb-3 text-left">
              <button class="js-btn-hint btn-hint !m-0" type="button">💡 Ver pista de color</button>
              <div class="js-hint-box hint-text hidden !text-left"></div>
            </div>
            <div class="grid grid-cols-1 gap-4 js-options-grid">
               <!-- Opciones tablet -->
            </div>
          </div>
        </div>
      </main>
      
      <footer class="w-full h-16 flex items-center justify-between px-12 border-t-2 border-primary bg-white z-10">
        <p class="font-label-mono text-[10px] text-secondary">RETRO SHIRT QUIZ • DAYLIGHT UNITY PULSE EDITION</p>
        <div class="flex items-center gap-4">
          <span class="font-label-mono text-xs uppercase opacity-60">Racha de victorias</span>
          <div class="w-12 h-8 bento-border bg-primary flex items-center justify-center text-on-primary">
            <span class="font-display-xl text-lg js-current-streak">0</span>
          </div>
        </div>
      </footer>
    </div>
  </div>

  <!-- ==================== PANTALLA GAME OVER (RESPONSIVA UNIFICADA) ==================== -->
  <div id="game-over-screen" class="js-game-over-screen hidden bg-background text-on-background min-h-screen flex flex-col w-full">
    <header class="bg-white border-b-2 border-primary w-full top-0 left-0 z-10 h-16 flex items-center justify-between px-6">
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-primary">sports_soccer</span>
        <h1 class="font-display-xl-mobile text-2xl uppercase tracking-tighter text-primary italic">RETRO SHIRT QUIZ</h1>
      </div>
    </header>
    
    <main class="flex-grow flex items-center justify-center p-6 md:p-12 relative z-10 w-full max-w-4xl mx-auto">
      <div class="w-full space-y-8">
        <div class="text-center stagger-load">
          <p class="font-label-mono text-label-mono uppercase tracking-widest text-secondary mb-2">Resumen de Partida</p>
          <h2 class="font-display-xl-mobile text-display-xl-mobile md:font-display-xl md:text-5xl uppercase italic js-game-over-message">Fin del Partido</h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white brutalist-border p-6 flex flex-col items-center justify-center text-center brutalist-shadow">
            <span class="font-label-mono text-label-mono uppercase text-secondary mb-4">Puntuación</span>
            <div class="font-display-xl-mobile text-[48px] md:text-5xl text-primary js-final-score">0</div>
            <div class="mt-4 px-3 py-1 bg-primary text-on-primary font-label-mono text-[11px] uppercase js-new-record-badge hidden">Nuevo Récord</div>
          </div>
          
          <div class="bg-pulse-neon brutalist-border p-6 flex flex-col items-center justify-center text-center relative overflow-hidden brutalist-shadow">
            <div class="absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none">
              <div class="w-full h-full" style="background-image: radial-gradient(circle, #fff 10%, transparent 10.5%); background-size: 20px 20px;"></div>
            </div>
            <span class="font-label-mono text-label-mono uppercase text-on-primary mb-4 relative z-10">Mejor Racha</span>
            <div class="font-display-xl-mobile text-[48px] md:text-5xl text-on-primary relative z-10 js-final-streak">0</div>
            <span class="material-symbols-outlined text-on-primary text-4xl mt-2 relative z-10" style="font-variation-settings: 'FILL' 1;">local_fire_department</span>
          </div>
          
          <div class="bg-white brutalist-border p-6 flex flex-col items-center justify-center text-center brutalist-shadow">
            <span class="font-label-mono text-label-mono uppercase text-secondary mb-4">Descubiertas</span>
            <div class="font-display-xl-mobile text-[48px] md:text-5xl text-primary js-final-guessed">0/50</div>
            <div class="w-full bg-[#eeeeee] h-2 mt-6 brutalist-border overflow-hidden">
              <div class="bg-primary h-full js-final-guessed-progress" style="width: 0%;"></div>
            </div>
          </div>
        </div>
        
        <div class="text-center">
          <span class="rank-badge js-rank-badge font-bold">Novato del banquillo</span>
        </div>

        <div class="flex flex-col md:flex-row gap-6">
          <button class="flex-grow bg-primary text-on-primary font-headline-md text-lg uppercase py-5 brutalist-border brutalist-shadow button-shift flex items-center justify-center gap-3 js-btn-retry">
            <span class="material-symbols-outlined text-white">replay</span>
            <span class="text-white">Jugar de Nuevo</span>
          </button>
          <button class="flex-grow bg-white text-primary font-headline-md text-lg uppercase py-5 brutalist-border brutalist-shadow button-shift flex items-center justify-center gap-3 js-btn-menu">
            <span class="material-symbols-outlined">home</span>
            <span>Menú principal</span>
          </button>
        </div>
      </div>
    </main>
    
    <footer class="mt-auto py-8 text-center opacity-40">
      <p class="font-label-mono text-[9px] uppercase tracking-[0.2em]">© FIFA 2026 • RETRO SHIRT QUIZ • OFFICIAL DIGITAL EXPERIENCE</p>
    </footer>
  </div>

  <!-- ==================== MODAL DE FEEDBACK ==================== -->
  <div id="feedback-modal" class="modal-overlay hidden js-feedback-modal" role="dialog" aria-modal="true">
    <div class="modal-content bento-border brutalist-shadow bg-white p-6 max-w-sm w-full animate-bounce-in">
      <div class="feedback-header flex items-center gap-3 mb-4">
        <span id="feedback-icon" class="feedback-emoji text-3xl js-feedback-icon">🎉</span>
        <h2 id="feedback-title" class="font-headline-md text-2xl uppercase js-feedback-title">¡Correcto!</h2>
      </div>
      <p id="correct-answer-reveal" class="correct-reveal-text font-bold text-[#FF007A] mb-4 leading-snug js-correct-answer-reveal"></p>
      <div class="history-context bg-gray-100 bento-border p-4 mb-6 max-h-40 overflow-y-auto">
        <h4 class="font-label-mono text-xs text-secondary uppercase font-bold mb-2">Historia de la camiseta</h4>
        <p id="shirt-description" class="text-sm leading-relaxed text-on-surface-variant js-shirt-description"></p>
      </div>
      <button id="btn-next" class="w-full bg-primary text-on-primary font-headline-md text-lg uppercase py-4 bento-border brutalist-shadow button-shift flex items-center justify-center gap-2 js-btn-next">
        <span class="text-white">Siguiente camiseta</span> <span class="material-symbols-outlined text-white">arrow_forward</span>
      </button>
    </div>
  </div>
</div>

<!-- ==================== LOGICA Y SCRIPTS ==================== -->
<script>
  import shirtsData from '../data/shirts.json';
  import type { Shirt } from '../data/shirts';
  import { getShirtImageCandidates, searchShirtImageUrl } from '../data/shirts';

  const shirts = shirtsData as Shirt[];
  const LETTERS = ['A', 'B', 'C', 'D'];

  let currentMode = 'team';
  let currentQuestionIndex = 0;
  let score = 0;
  let streak = 0;
  let maxStreak = 0;
  let lives = 3;
  let currentShirt: Shirt | null = null;
  let selectedShirts: Shirt[] = [];
  let isAnswered = false;

  // Pantallas
  const startScreens = document.querySelectorAll('.js-start-screen');
  const gameScreens = document.querySelectorAll('.js-game-screen');
  const feedbackModals = document.querySelectorAll('.js-feedback-modal');
  const gameOverScreens = document.querySelectorAll('.js-game-over-screen');

  // Funciones de utilidad para actualizar en lote
  function showScreen(screenType: 'start' | 'game' | 'gameover') {
    startScreens.forEach(el => screenType === 'start' ? el.classList.remove('hidden') : el.classList.add('hidden'));
    gameScreens.forEach(el => screenType === 'game' ? el.classList.remove('hidden') : el.classList.add('hidden'));
    gameOverScreens.forEach(el => screenType === 'gameover' ? el.classList.remove('hidden') : el.classList.add('hidden'));
  }

  function updateTextContent(selector: string, text: string) {
    document.querySelectorAll(selector).forEach(el => el.textContent = text);
  }

  function updateHeartsUI() {
    const hearts = document.querySelectorAll('.js-heart');
    hearts.forEach((heart, idx) => {
      const heartIdx = idx % 3;
      if (heartIdx < lives) {
        (heart as HTMLElement).style.setProperty("font-variation-settings", "'FILL' 1");
        (heart as HTMLElement).classList.remove('opacity-30');
      } else {
        (heart as HTMLElement).style.setProperty("font-variation-settings", "'FILL' 0");
        (heart as HTMLElement).classList.add('opacity-30');
      }
    });
  }

  function updateProgress() {
    const pct = (currentQuestionIndex / selectedShirts.length) * 100;
    document.querySelectorAll('.js-progress-fill').forEach(el => {
      (el as HTMLElement).style.width = `${pct}%`;
    });
    const soccerIcon = document.getElementById('soccer-indicator-tablet');
    if (soccerIcon) {
      soccerIcon.style.left = `${pct}%`;
    }
  }

  function playSound(type: 'correct' | 'incorrect' | 'gameover' | 'hint') {
    try {
      const AudioCtx = window.AudioContext || (window as any).webkitAudioContext;
      if (!AudioCtx) return;
      const ctx = new AudioCtx();
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain);
      gain.connect(ctx.destination);

      if (type === 'correct') {
        osc.type = 'sine';
        osc.frequency.setValueAtTime(523.25, ctx.currentTime);
        osc.frequency.setValueAtTime(659.25, ctx.currentTime + 0.08);
        osc.frequency.setValueAtTime(783.99, ctx.currentTime + 0.16);
        osc.frequency.setValueAtTime(1046.5, ctx.currentTime + 0.24);
        gain.gain.setValueAtTime(0.12, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.45);
        osc.start(ctx.currentTime);
        osc.stop(ctx.currentTime + 0.45);
      } else if (type === 'incorrect') {
        osc.type = 'sawtooth';
        osc.frequency.setValueAtTime(220, ctx.currentTime);
        osc.frequency.linearRampToValueAtTime(110, ctx.currentTime + 0.3);
        gain.gain.setValueAtTime(0.1, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.35);
        osc.start(ctx.currentTime);
        osc.stop(ctx.currentTime + 0.35);
      } else if (type === 'hint') {
        osc.type = 'triangle';
        osc.frequency.setValueAtTime(440, ctx.currentTime);
        osc.frequency.setValueAtTime(554.37, ctx.currentTime + 0.1);
        gain.gain.setValueAtTime(0.08, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.25);
        osc.start(ctx.currentTime);
        osc.stop(ctx.currentTime + 0.25);
      } else {
        osc.type = 'sine';
        [392, 349.23, 311.13, 261.63].forEach((f, i) => {
          osc.frequency.setValueAtTime(f, ctx.currentTime + i * 0.15);
        });
        gain.gain.setValueAtTime(0.1, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.8);
        osc.start(ctx.currentTime);
        osc.stop(ctx.currentTime + 0.8);
      }
    } catch {
      // Ignorar bloqueado
    }
  }

  function getRankTitle(s: number): string {
    if (s >= 4500) return 'Leyenda del Mundial';
    if (s >= 3000) return 'Crack historico';
    if (s >= 1800) return 'Aficionado experto';
    if (s >= 800) return 'Hincha de cultura';
    return 'Novato del banquillo';
  }

  function init() {
    const hs = localStorage.getItem('high_score') || '0';
    const ms = localStorage.getItem('max_streak') || '0';
    updateTextContent('.js-global-high-score', hs);
    updateTextContent('.js-global-max-streak', ms);
  }

  // Inicializar botones de modo
  document.querySelectorAll('.js-mode-button').forEach((button) => {
    button.addEventListener('click', (e) => {
      const mode = (e.currentTarget as HTMLButtonElement).dataset.mode!;
      startGame(mode);
    });
  });

  function startGame(mode: string) {
    currentMode = mode;
    score = 0;
    streak = 0;
    maxStreak = 0;
    lives = 3;
    currentQuestionIndex = 0;
    isAnswered = false;
    selectedShirts = [...shirts].sort(() => Math.random() - 0.5);

    updateHeartsUI();
    updateTextContent('.js-current-score', '0');
    updateStreakUI();
    updateProgress();

    showScreen('game');
    loadNextQuestion();
  }

  function updateStreakUI() {
    updateTextContent('.js-current-streak', streak.toString());
    document.querySelectorAll('.js-streak-badge').forEach(badge => {
      if (streak >= 3) {
        badge.classList.remove('hidden');
      } else {
        badge.classList.add('hidden');
      }
    });
  }

  function loadNextQuestion() {
    isAnswered = false;
    currentShirt = selectedShirts[currentQuestionIndex];
    
    updateTextContent('.js-question-index', `${currentQuestionIndex + 1}/${selectedShirts.length}`);
    updateProgress();

    // Pista
    document.querySelectorAll('.js-hint-box').forEach(box => {
      box.classList.add('hidden');
      box.textContent = '';
    });
    document.querySelectorAll('.js-btn-hint').forEach(btn => btn.classList.remove('hidden'));

    // Loader e Imagen
    const loaders = document.querySelectorAll('.js-image-loader');
    const images = document.querySelectorAll('.js-shirt-image');
    
    loaders.forEach(loader => loader.classList.remove('hidden'));
    images.forEach(img => img.classList.add('hidden'));

    const imageCandidates = getShirtImageCandidates(currentShirt);
    let candidateIndex = 0;
    let searchedCommons = false;

    images.forEach(img => {
      const imageElement = img as HTMLImageElement;
      
      imageElement.onload = () => {
        loaders.forEach(l => l.classList.add('hidden'));
        images.forEach(i => i.classList.remove('hidden'));
      };

      imageElement.onerror = () => {
        candidateIndex += 1;
        if (candidateIndex < imageCandidates.length) {
          imageElement.src = imageCandidates[candidateIndex];
          return;
        }
        if (!searchedCommons) {
          searchedCommons = true;
          searchShirtImageUrl(currentShirt!.team, currentShirt!.year).then((url) => {
            imageElement.src = url ?? '/favicon.svg';
          });
          return;
        }
        imageElement.src = '/favicon.svg';
      };
      
      imageElement.src = imageCandidates[0] ?? '/favicon.svg';
    });

    // Enunciado
    let questionText = '¿A que seleccion pertenece esta camiseta?';
    let typeBadgeText = 'Seleccion';
    
    if (currentMode === 'year') {
      questionText = '¿En que año/mundial se utilizo esta camiseta?';
      typeBadgeText = 'Año';
    } else if (currentMode === 'mixed') {
      const rand = Math.random() > 0.5;
      if (rand) {
        questionText = '¿A que seleccion pertenece esta camiseta?';
        typeBadgeText = 'Seleccion';
      } else {
        questionText = '¿En que año/mundial se utilizo esta camiseta?';
        typeBadgeText = 'Año';
      }
    }
    
    updateTextContent('.js-question-text', questionText);
    updateTextContent('.js-question-type-badge', typeBadgeText);

    generateOptions(typeBadgeText === 'Año');
  }

  function generateOptions(isYearQuestion: boolean) {
    if (!currentShirt) return;
    
    const correctValue = isYearQuestion ? currentShirt.year.toString() : currentShirt.team;
    
    // Obtener 3 valores incorrectos distintos
    const pool = new Set<string>();
    while (pool.size < 3) {
      const randomShirt = shirts[Math.floor(Math.random() * shirts.length)];
      const randomValue = isYearQuestion ? randomShirt.year.toString() : randomShirt.team;
      if (randomValue !== correctValue) {
        pool.add(randomValue);
      }
    }

    const options = [correctValue, ...Array.from(pool)].sort(() => Math.random() - 0.5);

    // Pintar los grids de opciones (móvil y tablet)
    const optionGrids = document.querySelectorAll('.js-options-grid');
    optionGrids.forEach(grid => {
      grid.innerHTML = '';
      options.forEach((opt, idx) => {
        const letter = LETTERS[idx];
        const btn = document.createElement('button');
        // Usamos las clases del mockup brutalista de Stitch
        btn.className = 'w-full brutalist-button brutalist-button-shadow bg-white hover:bg-surface-container-high py-4 px-6 flex justify-between items-center transition-all group button-shift';
        btn.type = 'button';
        btn.innerHTML = `
          <div class="flex items-center gap-4">
            <span class="font-label-mono text-xs border-2 border-primary group-hover:border-on-primary w-8 h-8 md:w-10 md:h-10 flex items-center justify-center">${letter}</span>
            <span class="font-headline-md text-base md:text-lg uppercase text-left leading-tight">${opt}</span>
          </div>
          <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-opacity">arrow_forward</span>
        `;

        btn.addEventListener('click', () => handleAnswerClick(opt, correctValue, btn));
        grid.appendChild(btn);
      });
    });
  }

  function handleAnswerClick(selected: string, correct: string, clickedBtn: HTMLButtonElement) {
    if (isAnswered) return;
    isAnswered = true;

    // Desactivar todos
    const allButtons = document.querySelectorAll('.js-options-grid button');
    allButtons.forEach(b => (b as HTMLButtonElement).disabled = true);

    const isCorrect = selected === correct;
    
    if (isCorrect) {
      playSound('correct');
      clickedBtn.classList.remove('bg-white');
      clickedBtn.classList.add('bg-pulse-neon', 'text-white');
      
      // Cambiar icono del boton clickeado a check
      const icon = clickedBtn.querySelector('.material-symbols-outlined');
      if (icon) {
        icon.classList.remove('opacity-0');
        icon.textContent = 'check_circle';
      }

      streak++;
      if (streak > maxStreak) maxStreak = streak;
      
      // Puntos: 100 base + 20 por racha (max 300)
      const bonus = Math.min(streak * 20, 200);
      score += 100 + bonus;
      updateTextContent('.js-current-score', score.toString());
      updateStreakUI();

      showFeedback(true);
    } else {
      playSound('incorrect');
      clickedBtn.classList.remove('bg-white');
      clickedBtn.classList.add('bg-[#ba1a1a]', 'text-white');
      
      const icon = clickedBtn.querySelector('.material-symbols-outlined');
      if (icon) {
        icon.classList.remove('opacity-0');
        icon.textContent = 'cancel';
      }

      // Buscar el boton correcto para marcarlo
      allButtons.forEach(b => {
        const btnText = b.querySelector('.font-headline-md')?.textContent || '';
        if (btnText === correct.toUpperCase()) {
          b.classList.remove('bg-white');
          b.classList.add('bg-neon-green', 'text-primary');
          const correctIcon = b.querySelector('.material-symbols-outlined');
          if (correctIcon) {
            correctIcon.classList.remove('opacity-0');
            correctIcon.textContent = 'check_circle';
          }
        }
      });

      streak = 0;
      lives--;
      updateHeartsUI();
      updateStreakUI();

      showFeedback(false);
    }
  }

  function showFeedback(isCorrect: boolean) {
    if (!currentShirt) return;
    playSound(isCorrect ? 'correct' : 'incorrect');

    updateTextContent('.js-feedback-icon', isCorrect ? '🎉' : '❌');
    updateTextContent('.js-feedback-title', isCorrect ? '¡Correcto!' : '¡Fallaste!');
    updateTextContent('.js-correct-answer-reveal', `La respuesta es: ${currentShirt.team} (${currentShirt.year})`);
    
    // Generar descripcion
    let desc = `Camiseta histórica utilizada por ${currentShirt.team} en el Mundial de ${currentShirt.year}.`;
    if (currentShirt.desc) {
      desc += ` ${currentShirt.desc}`;
    }
    updateTextContent('.js-shirt-description', desc);

    // Ajustar boton del modal si se queda sin vidas
    const nextBtn = document.querySelector('.js-btn-next');
    if (nextBtn) {
      if (lives === 0) {
        nextBtn.querySelector('span:first-child')!.textContent = 'Ver resultados';
      } else {
        nextBtn.querySelector('span:first-child')!.textContent = 'Siguiente camiseta';
      }
    }

    feedbackModals.forEach(m => m.classList.remove('hidden'));
  }

  // Listener boton next modal
  document.querySelectorAll('.js-btn-next').forEach(btn => {
    btn.addEventListener('click', () => {
      feedbackModals.forEach(m => m.classList.add('hidden'));
      if (lives === 0) {
        endGame();
      } else {
        currentQuestionIndex++;
        if (currentQuestionIndex >= selectedShirts.length) {
          endGame();
        } else {
          loadNextQuestion();
        }
      }
    });
  });

  function endGame() {
    playSound('gameover');
    showScreen('gameover');

    updateTextContent('.js-final-score', score.toString());
    updateTextContent('.js-final-streak', maxStreak.toString());
    updateTextContent('.js-final-guessed', `${currentQuestionIndex}/${selectedShirts.length}`);
    
    const pct = selectedShirts.length > 0 ? (currentQuestionIndex / selectedShirts.length) * 100 : 0;
    document.querySelectorAll('.js-final-guessed-progress').forEach(el => {
      (el as HTMLElement).style.width = `${pct}%`;
    });

    const rankTitle = getRankTitle(score);
    updateTextContent('.js-rank-badge', rankTitle);

    // Mensajes de fin
    let message = '¡Buen intento! Sigue entrenando para conocer las equipaciones históricas.';
    if (score >= 4500) {
      message = '¡Increíble! Eres una enciclopedia viviente del fútbol mundial. Récord absoluto.';
    } else if (score >= 2500) {
      message = '¡Excelente partido! Tienes una gran memoria y cultura de mundiales.';
    }
    updateTextContent('.js-game-over-message', message);

    // Guardar Records
    const hs = parseInt(localStorage.getItem('high_score') || '0', 10);
    const ms = parseInt(localStorage.getItem('max_streak') || '0', 10);
    
    let isNewRecord = false;
    if (score > hs) {
      localStorage.setItem('high_score', score.toString());
      isNewRecord = true;
    }
    if (maxStreak > ms) {
      localStorage.setItem('max_streak', maxStreak.toString());
    }

    document.querySelectorAll('.js-new-record-badge').forEach(badge => {
      if (isNewRecord) {
        badge.classList.remove('hidden');
      } else {
        badge.classList.add('hidden');
      }
    });

    init();
  }

  // Salida
  document.querySelectorAll('.js-btn-home').forEach(btn => {
    btn.addEventListener('click', () => {
      if (confirm('¿Abandonar la partida?')) {
        showScreen('start');
        init();
      }
    });
  });

  // Reintentar y Menú en GameOver
  document.querySelectorAll('.js-btn-retry').forEach(btn => {
    btn.addEventListener('click', () => {
      startGame(currentMode);
    });
  });

  document.querySelectorAll('.js-btn-menu').forEach(btn => {
    btn.addEventListener('click', () => {
      showScreen('start');
      init();
    });
  });

  // Pista
  document.querySelectorAll('.js-btn-hint').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!currentShirt) return;
      playSound('hint');
      
      const hints = [];
      if (currentShirt.color) hints.push(`Color principal: ${currentShirt.color}`);
      
      const hintText = hints.length > 0 ? hints.join(' | ') : 'No hay pistas adicionales para esta camiseta.';

      document.querySelectorAll('.js-hint-box').forEach(box => {
        box.textContent = hintText;
        box.classList.remove('hidden');
      });
      btn.classList.add('hidden');
    });
  });

  // Inicialización
  init();
</script>
