---
const SHIRT_COUNT = 50;
---

<div class="quiz-game-wrapper">
  <canvas id="confetti-canvas" class="confetti-canvas" aria-hidden="true"></canvas>

  <!-- INICIO -->
  <div id="start-screen" class="glass-panel screen-enter">
    <div class="hero-badge">⚽ {SHIRT_COUNT} camisetas legendarias</div>

    <div class="header-logo animate-bounce-in">
      <div class="logo-ring">
        <div class="logo-circle">
          <img src="/favicon.svg" alt="" class="logo-img" width="56" height="56" />
        </div>
      </div>
      <h1 class="gold-text title-main">Retro Shirt Quiz</h1>
      <p class="subtitle">Mundiales de Fútbol · 1930 — 2022</p>
    </div>

    <p class="hero-tagline">Reconoce las camisetas más icónicas de la historia. Tres vidas. Racha infinita.</p>

    <div class="stats-overview">
      <div class="stat-card">
        <span class="stat-icon">🏆</span>
        <span class="stat-label">Récord</span>
        <span id="global-high-score" class="stat-val gold-text">0</span>
      </div>
      <div class="stat-card">
        <span class="stat-icon">🔥</span>
        <span class="stat-label">Racha máx</span>
        <span id="global-max-streak" class="stat-val emerald-text">0</span>
      </div>
    </div>

    <div class="mode-selection">
      <h3>Elige tu desafío</h3>
      <button class="mode-card" data-mode="team" type="button">
        <span class="mode-card__icon">🌍</span>
        <span class="mode-card__body">
          <span class="mode-card__title">Adivinar Selección</span>
          <span class="mode-card__desc">¿De qué país es esta camiseta?</span>
        </span>
        <span class="mode-card__arrow">→</span>
      </button>
      <button class="mode-card" data-mode="year" type="button">
        <span class="mode-card__icon">📅</span>
        <span class="mode-card__body">
          <span class="mode-card__title">Adivinar Año</span>
          <span class="mode-card__desc">¿En qué Mundial la usaron?</span>
        </span>
        <span class="mode-card__arrow">→</span>
      </button>
      <button class="mode-card mode-card--featured" data-mode="mixed" type="button">
        <span class="mode-card__icon">⚡</span>
        <span class="mode-card__body">
          <span class="mode-card__title">Modo Mixto</span>
          <span class="mode-card__desc">País o año — nunca sabes cuál toca</span>
        </span>
        <span class="mode-card__arrow">→</span>
      </button>
    </div>

    <div class="pwa-install-container hidden" id="install-banner">
      <button class="btn-secondary" id="btn-install" type="button">📲 Instalar en el móvil</button>
    </div>

    <footer class="app-footer">
      <div>
        Camisetas · <a href="https://www.footballkitarchive.com/world-cup-kits-l308/" target="_blank" rel="noopener noreferrer">Football Kit Archive</a>
      </div>
      <div class="footer-credits">
        Desarrollado por <a href="https://github.com/moisesvalero" target="_blank" rel="noopener noreferrer">Moisés Valero</a>
      </div>
      <div class="footer-donate">
        <a href="https://www.paypal.com/cgi-bin/webscr?cmd=_donations&business=moi6%40outlook%2ecom&lc=ES&item_name=Retro%20Shirt%20Quiz&currency_code=EUR" target="_blank" rel="noopener noreferrer" class="btn-donate">
          Apoyar con ❤️ a moi6
        </a>
      </div>
    </footer>
  </div>

  <!-- JUEGO -->
  <div id="game-screen" class="glass-panel hidden">
    <div class="game-header">
      <button id="btn-home" class="btn-icon-round" type="button" aria-label="Salir">✕</button>
      <div class="score-container">
        <span class="score-label">Puntos</span>
        <span id="current-score" class="score-val">0</span>
      </div>
      <div class="hearts-container" aria-label="Vidas restantes">
        <span class="heart active"></span>
        <span class="heart active"></span>
        <span class="heart active"></span>
      </div>
    </div>

    <div class="progress-block">
      <div class="progress-meta">
        <span class="streak-badge hidden" id="streak-badge">🔥 <span id="current-streak">0</span></span>
        <span id="question-type-badge" class="question-badge">Selección</span>
        <span class="progress-indicator">Pregunta <span id="question-index">1</span></span>
      </div>
      <div class="progress-track">
        <div class="progress-fill" id="progress-fill"></div>
      </div>
    </div>

    <div class="shirt-card" id="shirt-card">
      <div class="shirt-card__label">Camiseta del día</div>
      <div class="image-wrapper">
        <div class="image-glow" aria-hidden="true"></div>
        <div class="image-skeleton" id="image-loader"></div>
        <img id="shirt-image" src="" alt="Camiseta histórica del Mundial" class="hidden" width="200" height="280" />
      </div>
      <button class="btn-hint" id="btn-hint" type="button">💡 Ver pista de color</button>
      <div class="hint-text hidden" id="hint-box"></div>
    </div>

    <div class="options-container" id="options-grid"></div>
  </div>

  <!-- FEEDBACK -->
  <div id="feedback-modal" class="modal-overlay hidden" role="dialog" aria-modal="true">
    <div class="modal-content glass-panel">
      <div class="feedback-header">
        <span id="feedback-icon" class="feedback-emoji"></span>
        <h2 id="feedback-title"></h2>
      </div>
      <p id="correct-answer-reveal" class="correct-reveal-text"></p>
      <div class="history-context">
        <h4>Historia de la camiseta</h4>
        <p id="shirt-description"></p>
      </div>
      <button id="btn-next" class="btn-primary" type="button">
        Siguiente camiseta <span class="btn-icon">→</span>
      </button>
    </div>
  </div>

  <!-- GAME OVER -->
  <div id="game-over-screen" class="glass-panel hidden">
    <div id="rank-badge" class="rank-badge">Novato</div>
    <h2 class="gold-text">Fin del partido</h2>
    <p class="game-over-subtitle" id="game-over-message"></p>

    <div class="final-stats">
      <div class="final-stat-row">
        <span>Puntuación</span>
        <span id="final-score" class="gold-text font-display">0</span>
      </div>
      <div class="final-stat-row">
        <span>Mejor racha</span>
        <span id="final-streak" class="emerald-text font-display">0</span>
      </div>
      <div class="final-stat-row">
        <span>Descubiertas</span>
        <span id="final-guessed" class="font-display">0</span>
      </div>
    </div>

    <div class="game-over-actions">
      <button id="btn-retry" class="btn-primary" type="button">🔄 Jugar de nuevo</button>
      <button id="btn-menu" class="btn-secondary" type="button">🏠 Menú principal</button>
    </div>
  </div>
</div>

<style>
  .quiz-game-wrapper {
    width: 100%;
    position: relative;
  }

  .confetti-canvas {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 200;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pitch-light);
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid var(--border-glow);
    padding: 0.35rem 0.85rem;
    border-radius: 99px;
    margin-bottom: 1.25rem;
  }

  .header-logo {
    text-align: center;
    margin-bottom: 1rem;
  }

  .logo-ring {
    width: 96px;
    height: 96px;
    margin: 0 auto 1rem;
    border-radius: 50%;
    padding: 3px;
    background: linear-gradient(135deg, var(--gold), var(--pitch-light), var(--gold));
    animation: spin-slow 12s linear infinite;
  }

  @keyframes spin-slow {
    to { transform: rotate(360deg); }
  }

  .logo-circle {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: var(--bg-dark);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-img {
    width: 56px;
    height: 56px;
    object-fit: contain;
  }

  .title-main {
    font-size: clamp(2.4rem, 9vw, 3rem);
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .subtitle {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--text-secondary);
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .hero-tagline {
    text-align: center;
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.55;
    margin-bottom: 1.5rem;
    padding: 0 0.5rem;
  }

  .stats-overview {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .stat-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 0.85rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  .stat-icon { font-size: 1.1rem; }

  .stat-label {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .stat-val {
    font-size: 1.65rem;
    font-family: var(--font-display);
    line-height: 1;
  }

  .mode-selection h3 {
    font-size: 0.72rem;
    color: var(--text-muted);
    text-align: center;
    letter-spacing: 0.14em;
    margin-bottom: 0.75rem;
    font-family: var(--font-sans);
    font-weight: 600;
    text-transform: uppercase;
  }

  .mode-card {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    width: 100%;
    padding: 0.95rem 1rem;
    margin-bottom: 0.6rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    cursor: pointer;
    text-align: left;
    color: inherit;
    font-family: inherit;
    transition: var(--transition);
  }

  .mode-card:hover {
    background: var(--bg-card-hover);
    border-color: rgba(16, 185, 129, 0.25);
    transform: translateX(4px);
  }

  .mode-card--featured {
    border-color: rgba(245, 197, 24, 0.25);
    background: linear-gradient(135deg, rgba(245, 197, 24, 0.06) 0%, rgba(16, 185, 129, 0.06) 100%);
  }

  .mode-card__icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .mode-card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .mode-card__title {
    font-weight: 700;
    font-size: 0.95rem;
  }

  .mode-card__desc {
    font-size: 0.78rem;
    color: var(--text-secondary);
  }

  .mode-card__arrow {
    color: var(--text-muted);
    font-size: 1.1rem;
    transition: transform var(--transition);
  }

  .mode-card:hover .mode-card__arrow {
    transform: translateX(3px);
    color: var(--pitch-light);
  }

  .pwa-install-container { margin-top: 1rem; }

  .app-footer {
    margin-top: 1.5rem;
    text-align: center;
    font-size: 0.72rem;
    color: var(--text-muted);
    line-height: 1.6;
    border-top: 1px solid #e2e8f0;
    padding-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .app-footer a {
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 500;
    transition: var(--transition);
  }

  .app-footer a:hover {
    color: var(--pitch);
  }

  .footer-credits a {
    color: var(--text-primary);
    font-weight: 600;
  }

  .footer-donate {
    margin-top: 0.25rem;
  }

  .btn-donate {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    background: #fef2f2;
    border: 1px solid #fee2e2;
    color: #ef4444 !important;
    padding: 0.35rem 0.85rem;
    border-radius: 99px;
    font-weight: 600 !important;
    font-size: 0.7rem;
    box-shadow: 0 1px 2px rgba(239, 68, 68, 0.05);
    transition: var(--transition);
  }

  .btn-donate:hover {
    background: #fee2e2;
    transform: translateY(-1px);
    box-shadow: 0 3px 8px rgba(239, 68, 68, 0.1);
  }

  /* Game */
  .game-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .btn-icon-round {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--border-color);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-secondary);
    font-size: 0.9rem;
    cursor: pointer;
    transition: var(--transition);
  }

  .btn-icon-round:hover {
    color: var(--text-primary);
    border-color: rgba(255, 255, 255, 0.15);
  }

  .score-container { text-align: center; }

  .score-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .score-val {
    font-size: 1.6rem;
    font-family: var(--font-display);
    color: var(--gold);
    line-height: 1.1;
  }

  .hearts-container {
    display: flex;
    gap: 0.35rem;
  }

  .heart {
    width: 22px;
    height: 22px;
    border-radius: 4px;
    background: rgba(244, 63, 94, 0.15);
    border: 1px solid rgba(244, 63, 94, 0.2);
    transition: var(--transition);
    position: relative;
  }

  .heart::after {
    content: '♥';
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    color: var(--error);
    opacity: 0.25;
  }

  .heart.active {
    background: rgba(244, 63, 94, 0.25);
    border-color: var(--error);
    box-shadow: 0 0 12px rgba(244, 63, 94, 0.35);
  }

  .heart.active::after { opacity: 1; }

  .progress-block { margin-bottom: 1.1rem; }

  .progress-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    font-size: 0.75rem;
  }

  .streak-badge {
    font-weight: 700;
    color: #f59e0b;
    background: rgba(245, 158, 11, 0.12);
    border: 1px solid rgba(245, 158, 11, 0.3);
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
    animation: pulse 1.5s ease infinite;
  }

  .question-badge {
    font-weight: 700;
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--pitch-light);
    background: rgba(16, 185, 129, 0.1);
    padding: 0.2rem 0.55rem;
    border-radius: 6px;
    border: 1px solid var(--border-glow);
  }

  .progress-indicator {
    color: var(--text-muted);
    font-weight: 600;
    margin-left: auto;
  }

  .progress-track {
    height: 4px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 99px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--pitch-light), var(--gold));
    border-radius: 99px;
    transition: width 0.5s var(--ease-out);
    box-shadow: 0 0 10px var(--pitch-glow);
  }

  .shirt-card {
    background: #ffffff;
    border: 1.5px solid #cbd5e1;
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    margin-bottom: 1.25rem;
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.02);
  }

  .shirt-card__label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-align: center;
    margin-bottom: 0.75rem;
  }

  .image-wrapper {
    width: 100%;
    aspect-ratio: 3/4;
    max-height: 280px;
    border-radius: var(--radius-md);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 1rem;
    background: radial-gradient(circle at 50% 50%, rgba(59, 130, 246, 0.08) 0%, rgba(255, 255, 255, 0) 70%), #f8fafc;
    border: 1.5px solid #cbd5e1;
  }

  .image-glow {
    position: absolute;
    width: 60%;
    height: 50%;
    top: 20%;
    left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(ellipse, rgba(59, 130, 246, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .image-skeleton {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 25%, rgba(15, 23, 42, 0.02) 50%, transparent 75%);
    background-size: 200% 100%;
    animation: shimmer 1.4s infinite;
    border-radius: var(--radius-md);
  }

  .image-wrapper img {
    height: 100%;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    filter: drop-shadow(0 8px 20px rgba(15, 23, 42, 0.12));
    z-index: 1;
    transition: transform 0.4s var(--ease-spring);
  }

  .shirt-card:hover img {
    transform: scale(1.02);
  }

  .btn-hint {
    display: block;
    margin: 0.85rem auto 0;
    background: transparent;
    border: 1.5px dashed rgba(59, 130, 246, 0.3);
    color: var(--text-secondary);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.4rem 1rem;
    border-radius: 99px;
    cursor: pointer;
    transition: var(--transition);
  }

  .btn-hint:hover {
    color: var(--pitch);
    border-color: var(--pitch);
    background: rgba(5, 150, 105, 0.05);
  }

  .hint-text {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-align: center;
    padding: 0.75rem;
    border-radius: var(--radius-sm);
    background: #f8fafc;
    border: 1.5px solid #e2e8f0;
    animation: screenIn 0.3s var(--ease-out);
  }

  .options-container {
    display: grid;
    gap: 0.6rem;
  }

  .btn-option {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    width: 100%;
    padding: 0.95rem 1.15rem;
    background: #ffffff;
    border: 1.5px solid #e2e8f0;
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    text-align: left;
    box-shadow: 0 2px 4px rgba(15, 23, 42, 0.015);
    transition: var(--transition);
  }

  .btn-option:hover:not(:disabled) {
    background: var(--bg-card-hover);
    border-color: #cbd5e1;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.05);
  }

  .btn-option__letter {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-size: 0.75rem;
    font-weight: 800;
    background: #f1f5f9;
    color: #475569;
    border: 1.5px solid #cbd5e1;
    transition: var(--transition);
  }

  .btn-option:hover:not(:disabled) .btn-option__letter {
    background: #e2e8f0;
    color: #0f1c3f;
    border-color: #94a3b8;
  }

  .btn-option.correct {
    background: #10b981 !important;
    border-color: #10b981 !important;
    color: #ffffff !important;
    box-shadow: 0 4px 14px rgba(16, 185, 129, 0.3) !important;
  }

  .btn-option.correct .btn-option__letter {
    background: #ffffff !important;
    color: #047857 !important;
    border-color: transparent !important;
  }

  .btn-option.incorrect {
    background: #ef4444 !important;
    border-color: #ef4444 !important;
    color: #ffffff !important;
    box-shadow: 0 4px 14px rgba(239, 68, 68, 0.3) !important;
  }

  .btn-option.incorrect .btn-option__letter {
    background: #ffffff !important;
    color: #b91c1c !important;
    border-color: transparent !important;
  }

  .btn-option:disabled { cursor: default; }

  /* Modal */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 1rem;
    padding-bottom: max(1rem, env(safe-area-inset-bottom));
    background: rgba(3, 8, 6, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .modal-content {
    width: 100%;
    max-width: var(--max-width);
    animation: modalUp 0.4s var(--ease-spring) both;
  }

  @keyframes modalUp {
    from { transform: translateY(100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .feedback-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .feedback-emoji { font-size: 2rem; }

  #feedback-title { font-size: 1.75rem; }

  .correct-reveal-text {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .history-context {
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 1rem;
    margin-bottom: 1.25rem;
    max-height: 160px;
    overflow-y: auto;
  }

  .history-context h4 {
    font-size: 0.68rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
    font-family: var(--font-sans);
    font-weight: 700;
  }

  .history-context p {
    font-size: 0.88rem;
    line-height: 1.55;
    color: var(--text-secondary);
  }

  /* Game over */
  #game-over-screen {
    text-align: center;
    padding: 2rem 1.25rem;
  }

  .rank-badge {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 1.1rem;
    letter-spacing: 0.12em;
    color: var(--gold);
    border: 1px solid rgba(245, 197, 24, 0.35);
    background: rgba(245, 197, 24, 0.08);
    padding: 0.35rem 1rem;
    border-radius: 99px;
    margin-bottom: 0.75rem;
  }

  #game-over-screen h2 {
    font-size: 2.5rem;
    margin-bottom: 0.35rem;
  }

  .game-over-subtitle {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }

  .final-stats {
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 1rem 1.15rem;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .final-stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .final-stat-row span:last-child {
    font-size: 1.5rem;
    color: var(--text-primary);
  }

  .game-over-actions {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .btn-icon { font-size: 1.1rem; }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.75; }
  }

  @media (min-width: 480px) {
    .modal-overlay { align-items: center; }
    .modal-content { animation-name: screenIn; }
  }
</style>

<script>
  import shirtsData from '../data/shirts.json';
  import type { Shirt } from '../data/shirts';
  import { getShirtImageCandidates, searchShirtImageUrl } from '../data/shirts';

  const shirts = shirtsData as Shirt[];
  const LETTERS = ['A', 'B', 'C', 'D'];

  let currentMode = 'team';
  let currentQuestionIndex = 0;
  let score = 0;
  let streak = 0;
  let maxStreak = 0;
  let lives = 3;
  let currentShirt: Shirt | null = null;
  let selectedShirts: Shirt[] = [];
  let isAnswered = false;

  const startScreen = document.getElementById('start-screen')!;
  const gameScreen = document.getElementById('game-screen')!;
  const feedbackModal = document.getElementById('feedback-modal')!;
  const gameOverScreen = document.getElementById('game-over-screen')!;

  const globalHighScoreLabel = document.getElementById('global-high-score')!;
  const globalMaxStreakLabel = document.getElementById('global-max-streak')!;
  const currentScoreLabel = document.getElementById('current-score')!;
  const currentStreakLabel = document.getElementById('current-streak')!;
  const streakBadge = document.getElementById('streak-badge')!;
  const questionIndexLabel = document.getElementById('question-index')!;
  const questionTypeBadge = document.getElementById('question-type-badge')!;
  const progressFill = document.getElementById('progress-fill')!;
  const hearts = document.querySelectorAll('.heart');

  const shirtCard = document.getElementById('shirt-card')!;
  const shirtImage = document.getElementById('shirt-image') as HTMLImageElement;
  const imageLoader = document.getElementById('image-loader')!;
  const btnHint = document.getElementById('btn-hint')!;
  const hintBox = document.getElementById('hint-box')!;
  const optionsGrid = document.getElementById('options-grid')!;

  const feedbackIcon = document.getElementById('feedback-icon')!;
  const feedbackTitle = document.getElementById('feedback-title')!;
  const correctAnswerReveal = document.getElementById('correct-answer-reveal')!;
  const shirtDescription = document.getElementById('shirt-description')!;

  const finalScore = document.getElementById('final-score')!;
  const finalStreak = document.getElementById('final-streak')!;
  const finalGuessed = document.getElementById('final-guessed')!;
  const gameOverMessage = document.getElementById('game-over-message')!;
  const rankBadge = document.getElementById('rank-badge')!;

  const btnHome = document.getElementById('btn-home')!;
  const btnNext = document.getElementById('btn-next')!;
  const btnRetry = document.getElementById('btn-retry')!;
  const btnMenu = document.getElementById('btn-menu')!;
  const confettiCanvas = document.getElementById('confetti-canvas') as HTMLCanvasElement;

  function playSound(type: 'correct' | 'incorrect' | 'gameover' | 'hint') {
    try {
      const AudioCtx = window.AudioContext || (window as unknown as { webkitAudioContext: typeof AudioContext }).webkitAudioContext;
      if (!AudioCtx) return;
      const ctx = new AudioCtx();
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain);
      gain.connect(ctx.destination);

      if (type === 'correct') {
        osc.type = 'sine';
        osc.frequency.setValueAtTime(523.25, ctx.currentTime);
        osc.frequency.setValueAtTime(659.25, ctx.currentTime + 0.08);
        osc.frequency.setValueAtTime(783.99, ctx.currentTime + 0.16);
        osc.frequency.setValueAtTime(1046.5, ctx.currentTime + 0.24);
        gain.gain.setValueAtTime(0.12, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.45);
        osc.start(ctx.currentTime);
        osc.stop(ctx.currentTime + 0.45);
      } else if (type === 'incorrect') {
        osc.type = 'sawtooth';
        osc.frequency.setValueAtTime(220, ctx.currentTime);
        osc.frequency.linearRampToValueAtTime(110, ctx.currentTime + 0.3);
        gain.gain.setValueAtTime(0.1, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.35);
        osc.start(ctx.currentTime);
        osc.stop(ctx.currentTime + 0.35);
      } else if (type === 'hint') {
        osc.type = 'triangle';
        osc.frequency.setValueAtTime(440, ctx.currentTime);
        osc.frequency.setValueAtTime(554.37, ctx.currentTime + 0.1);
        gain.gain.setValueAtTime(0.08, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.25);
        osc.start(ctx.currentTime);
        osc.stop(ctx.currentTime + 0.25);
      } else {
        osc.type = 'sine';
        [392, 349.23, 311.13, 261.63].forEach((f, i) => {
          osc.frequency.setValueAtTime(f, ctx.currentTime + i * 0.15);
        });
        gain.gain.setValueAtTime(0.1, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.8);
        osc.start(ctx.currentTime);
        osc.stop(ctx.currentTime + 0.8);
      }
    } catch {
      /* audio bloqueado */
    }
  }

  function burstConfetti() {
    const ctx = confettiCanvas.getContext('2d');
    if (!ctx) return;
    const draw = ctx;
    confettiCanvas.width = window.innerWidth;
    confettiCanvas.height = window.innerHeight;
    const colors = ['#14d99a', '#f5c518', '#fff', '#22c55e'];
    const particles = Array.from({ length: 60 }, () => ({
      x: confettiCanvas.width / 2,
      y: confettiCanvas.height * 0.45,
      vx: (Math.random() - 0.5) * 14,
      vy: Math.random() * -12 - 4,
      color: colors[Math.floor(Math.random() * colors.length)],
      size: Math.random() * 6 + 3,
      life: 1,
    }));

    let frame = 0;
    function tick() {
      draw.clearRect(0, 0, confettiCanvas.width, confettiCanvas.height);
      let alive = false;
      for (const p of particles) {
        if (p.life <= 0) continue;
        alive = true;
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.35;
        p.life -= 0.018;
        draw.globalAlpha = p.life;
        draw.fillStyle = p.color;
        draw.fillRect(p.x, p.y, p.size, p.size * 0.6);
      }
      frame++;
      if (alive && frame < 90) requestAnimationFrame(tick);
      else draw.clearRect(0, 0, confettiCanvas.width, confettiCanvas.height);
    }
    tick();
  }

  function getRankTitle(s: number): string {
    if (s >= 4500) return 'Leyenda del Mundial';
    if (s >= 3000) return 'Crack histórico';
    if (s >= 1800) return 'Aficionado experto';
    if (s >= 800) return 'Hincha de cultura';
    return 'Novato del banquillo';
  }

  function init() {
    globalHighScoreLabel.textContent = localStorage.getItem('high_score') || '0';
    globalMaxStreakLabel.textContent = localStorage.getItem('max_streak') || '0';
  }

  function updateProgress() {
    const pct = ((currentQuestionIndex) / selectedShirts.length) * 100;
    progressFill.style.width = `${pct}%`;
  }

  let deferredPrompt: Event | null = null;
  const installBanner = document.getElementById('install-banner')!;
  const btnInstall = document.getElementById('btn-install')!;

  window.addEventListener('beforeinstallprompt', (e) => {
    e.preventDefault();
    deferredPrompt = e;
    installBanner.classList.remove('hidden');
  });

  btnInstall.addEventListener('click', async () => {
    const prompt = deferredPrompt as (Event & { prompt: () => void; userChoice: Promise<{ outcome: string }> }) | null;
    if (!prompt) return;
    prompt.prompt();
    await prompt.userChoice;
    deferredPrompt = null;
    installBanner.classList.add('hidden');
  });

  document.querySelectorAll('.mode-card').forEach((button) => {
    button.addEventListener('click', (e) => {
      const mode = (e.currentTarget as HTMLButtonElement).dataset.mode!;
      startGame(mode);
    });
  });

  function startGame(mode: string) {
    currentMode = mode;
    score = 0;
    streak = 0;
    maxStreak = 0;
    lives = 3;
    currentQuestionIndex = 0;
    isAnswered = false;
    selectedShirts = [...shirts].sort(() => Math.random() - 0.5);

    updateHeartsUI();
    currentScoreLabel.textContent = '0';
    updateStreakUI();
    updateProgress();

    startScreen.classList.add('hidden');
    gameOverScreen.classList.add('hidden');
    gameScreen.classList.remove('hidden');
    gameScreen.classList.add('screen-enter');

    loadNextQuestion();
  }

  function loadNextQuestion() {
    isAnswered = false;
    currentShirt = selectedShirts[currentQuestionIndex];
    questionIndexLabel.textContent = `${currentQuestionIndex + 1}/${selectedShirts.length}`;
    updateProgress();

    hintBox.classList.add('hidden');
    hintBox.textContent = '';
    btnHint.classList.remove('hidden');

    imageLoader.classList.remove('hidden');
    shirtImage.classList.add('hidden');

    const imageCandidates = getShirtImageCandidates(currentShirt);
    let candidateIndex = 0;
    let searchedCommons = false;

    shirtImage.onload = () => {
      imageLoader.classList.add('hidden');
      shirtImage.classList.remove('hidden');
    };

    shirtImage.onerror = () => {
      candidateIndex += 1;
      if (candidateIndex < imageCandidates.length) {
        shirtImage.src = imageCandidates[candidateIndex];
        return;
      }
      if (!searchedCommons) {
        searchedCommons = true;
        searchShirtImageUrl(currentShirt!.team, currentShirt!.year).then((url) => {
          shirtImage.src = url ?? '/favicon.svg';
          imageLoader.classList.add('hidden');
          shirtImage.classList.remove('hidden');
        });
        return;
      }
      imageLoader.classList.add('hidden');
      shirtImage.classList.remove('hidden');
      shirtImage.src = '/favicon.svg';
    };

    shirtImage.src = imageCandidates[0] ?? '/favicon.svg';
    generateOptions();
  }

  function generateOptions() {
    optionsGrid.innerHTML = '';

    let questionType = currentMode;
    if (currentMode === 'mixed') {
      questionType = Math.random() > 0.5 ? 'team' : 'year';
    }

    questionTypeBadge.textContent = questionType === 'team' ? '🌍 Selección' : '📅 Año';

    let correctAnswer = '';
    let allOptions: string[] = [];

    if (questionType === 'team') {
      correctAnswer = currentShirt!.team;
      const uniqueTeams = [...new Set(shirts.map((s) => s.team))];
      const distractors = uniqueTeams
        .filter((t) => t !== correctAnswer)
        .sort(() => Math.random() - 0.5)
        .slice(0, 3);
      allOptions = [correctAnswer, ...distractors].sort(() => Math.random() - 0.5);
    } else {
      correctAnswer = currentShirt!.year.toString();
      const uniqueYears = [...new Set(shirts.map((s) => s.year.toString()))];
      const distractors = uniqueYears
        .filter((y) => y !== correctAnswer)
        .sort(() => Math.random() - 0.5)
        .slice(0, 3);
      allOptions = [correctAnswer, ...distractors].sort(() => Math.random() - 0.5);
    }

    allOptions.forEach((option, i) => {
      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'btn-option';
      button.dataset.value = option;
      button.dataset.correct = option === correctAnswer ? 'true' : 'false';
      button.innerHTML = `<span class="btn-option__letter">${LETTERS[i]}</span><span>${option}</span>`;
      button.addEventListener('click', () => handleAnswerSelect(button));
      optionsGrid.appendChild(button);
    });
  }

  function handleAnswerSelect(selectedButton: HTMLButtonElement) {
    if (isAnswered) return;
    isAnswered = true;

    const isCorrect = selectedButton.dataset.correct === 'true';

    document.querySelectorAll('.btn-option').forEach((btn) => {
      const b = btn as HTMLButtonElement;
      b.disabled = true;
      if (b.dataset.correct === 'true') b.classList.add('correct');
    });

    if (isCorrect) {
      selectedButton.classList.add('correct');
      shirtCard.classList.add('animate-success');
      setTimeout(() => shirtCard.classList.remove('animate-success'), 650);
      streak++;
      if (streak > maxStreak) maxStreak = streak;
      score += 100 + streak * 10;
      currentScoreLabel.textContent = score.toString();
      updateStreakUI();
      playSound('correct');
      burstConfetti();
      if (navigator.vibrate) navigator.vibrate([60]);
      showFeedbackModal(true);
    } else {
      selectedButton.classList.add('incorrect');
      shirtCard.classList.add('animate-shake');
      setTimeout(() => shirtCard.classList.remove('animate-shake'), 400);
      streak = 0;
      updateStreakUI();
      lives--;
      updateHeartsUI();
      playSound('incorrect');
      if (navigator.vibrate) navigator.vibrate([80, 40, 80]);
      showFeedbackModal(false);
    }
  }

  function showFeedbackModal(isCorrect: boolean) {
    if (isCorrect) {
      feedbackIcon.textContent = '⚽';
      feedbackTitle.textContent = '¡Gol!';
      feedbackTitle.className = 'emerald-text';
    } else {
      feedbackIcon.textContent = '🟥';
      feedbackTitle.textContent = 'Fuera de juego';
      feedbackTitle.className = 'error-text';
    }

    correctAnswerReveal.innerHTML = `Camiseta de <span class="gold-text">${currentShirt!.team}</span> · Mundial <span class="gold-text">${currentShirt!.year}</span>`;
    shirtDescription.textContent = currentShirt!.desc;

    setTimeout(() => feedbackModal.classList.remove('hidden'), 600);
  }

  btnNext.addEventListener('click', () => {
    feedbackModal.classList.add('hidden');
    currentQuestionIndex++;
    if (lives <= 0 || currentQuestionIndex >= selectedShirts.length) {
      endGame();
    } else {
      loadNextQuestion();
    }
  });

  function endGame() {
    playSound('gameover');
    gameScreen.classList.add('hidden');
    feedbackModal.classList.add('hidden');
    gameOverScreen.classList.remove('hidden');
    gameOverScreen.classList.add('screen-enter');

    progressFill.style.width = '100%';
    finalScore.textContent = score.toString();
    finalStreak.textContent = maxStreak.toString();
    finalGuessed.textContent = `${currentQuestionIndex}/${selectedShirts.length}`;
    rankBadge.textContent = getRankTitle(score);

    if (lives <= 0) {
      gameOverMessage.textContent = 'Sin vidas. Las leyendas del fútbol no se rinden — vuelve a intentarlo.';
    } else {
      gameOverMessage.textContent = '¡Histórico! Has recorrido las 50 camisetas más icónicas del Mundial.';
    }

    const localHighScore = parseInt(localStorage.getItem('high_score') || '0', 10);
    const localMaxStreak = parseInt(localStorage.getItem('max_streak') || '0', 10);

    if (score > localHighScore) {
      localStorage.setItem('high_score', score.toString());
      finalScore.innerHTML = `${score} <span class="new-record-badge">Récord</span>`;
    }
    if (maxStreak > localMaxStreak) {
      localStorage.setItem('max_streak', maxStreak.toString());
    }

    init();
  }

  btnHint.addEventListener('click', () => {
    playSound('hint');
    hintBox.textContent = `Color principal: ${currentShirt!.color.toLowerCase()}.`;
    hintBox.classList.remove('hidden');
    btnHint.classList.add('hidden');
  });

  function updateHeartsUI() {
    hearts.forEach((heart, idx) => {
      heart.classList.toggle('active', idx < lives);
    });
  }

  function updateStreakUI() {
    streakBadge.classList.toggle('hidden', streak < 3);
    if (streak >= 3) currentStreakLabel.textContent = streak.toString();
  }

  btnHome.addEventListener('click', () => {
    if (confirm('¿Abandonar la partida?')) {
      gameScreen.classList.add('hidden');
      startScreen.classList.remove('hidden');
    }
  });

  btnMenu.addEventListener('click', () => {
    gameOverScreen.classList.add('hidden');
    startScreen.classList.remove('hidden');
  });

  btnRetry.addEventListener('click', () => startGame(currentMode));

  init();
</script>
